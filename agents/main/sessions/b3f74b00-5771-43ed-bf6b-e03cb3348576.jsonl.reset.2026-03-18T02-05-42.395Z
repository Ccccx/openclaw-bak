" fill=\"#00d9ff\">📄 2026-03-16.md</text>\n    </g>\n    <g class=\"float-anim\" style=\"animation-delay: 0.6s\">\n      <rect x=\"20\" y=\"125\" width=\"160\" height=\"25\" rx=\"5\" fill=\"#2d3436\"/>\n      <text x=\"30\" y=\"142\" font-family=\"Arial\" font-size=\"10\" fill=\"#00d9ff\">📄 2026-03-15.md</text>\n    </g>\n  </g>\n\n  <!-- Session Transcripts -->\n  <g transform=\"translate(50, 480)\">\n    <rect x=\"0\" y=\"0\" width=\"200\" height=\"80\" rx=\"15\" fill=\"#1e272e\" stroke=\"#6c5ce7\" stroke-width=\"2\"/>\n    <text x=\"100\" y=\"25\" font-family=\"Arial\" font-size=\"14\" fill=\"#6c5ce7\" text-anchor=\"middle\" font-weight=\"bold\">💬 会话记录</text>\n    <text x=\"100\" y=\"45\" font-family=\"Arial\" font-size=\"9\" fill=\"#888\" text-anchor=\"middle\">Session Transcripts</text>\n    <text x=\"100\" y=\"62\" font-family=\"Arial\" font-size=\"9\" fill=\"#666\" text-anchor=\"middle\">JSONL 格式存储</text>\n  </g>\n\n  <!-- ==================== CENTER: Search Engine ==================== -->\n  \n  <!-- Hybrid Search Engine -->\n  <g transform=\"translate(320, 200)\">\n    <rect x=\"0\" y=\"0\" width=\"260\" height=\"280\" rx=\"20\" fill=\"url(#memGrad2)\" stroke=\"#e94560\" stroke-width=\"3\" filter=\"url(#memGlow)\"/>\n    <text x=\"130\" y=\"35\" font-family=\"Arial\" font-size=\"18\" fill=\"#fff\" text-anchor=\"middle\" font-weight=\"bold\">🔍 混合搜索引擎</text>\n    <text x=\"130\" y=\"55\" font-family=\"Arial\" font-size=\"10\" fill=\"#aaa\" text-anchor=\"middle\">Hybrid Search Engine</text>\n    \n    <!-- Vector Search -->\n    <g transform=\"translate(20, 75)\">\n      <rect x=\"0\" y=\"0\" width=\"100\" height=\"60\" rx=\"10\" fill=\"#1e272e\" stroke=\"#e94560\" stroke-width=\"2\" class=\"search-anim\"/>\n      <text x=\"50\" y=\"22\" font-family=\"Arial\" font-size=\"11\" fill=\"#e94560\" text-anchor=\"middle\" font-weight=\"bold\">Vector</text>\n      <text x=\"50\" y=\"40\" font-family=\"Arial\" font-size=\"9\" fill=\"#888\" text-anchor=\"middle\">语义相似度</text>\n      <text x=\"50\" y=\"52\" font-family=\"Arial\" font-size=\"8\" fill=\"#666\" text-anchor=\"middle\">cosine similarity</text>\n    </g>\n    \n    <!-- BM25 Search -->\n    <g transform=\"translate(140, 75)\">\n      <rect x=\"0\" y=\"0\" width=\"100\" height=\"60\" rx=\"10\" fill=\"#1e272e\" stroke=\"#00ff88\" stroke-width=\"2\" class=\"search-anim\"/>\n      <text x=\"50\" y=\"22\" font-family=\"Arial\" font-size=\"11\" fill=\"#00ff88\" text-anchor=\"middle\" font-weight=\"bold\">BM25</text>\n      <text x=\"50\" y=\"40\" font-family=\"Arial\" font-size=\"9\" fill=\"#888\" text-anchor=\"middle\">关键词匹配</text>\n      <text x=\"50\" y=\"52\" font-family=\"Arial\" font-size=\"8\" fill=\"#666\" text-anchor=\"middle\">full-text search</text>\n    </g>\n    \n    <!-- Score Merging -->\n    <g transform=\"translate(80, 150)\">\n      <rect x=\"0\" y=\"0\" width=\"100\" height=\"35\" rx=\"18\" fill=\"#0f3460\" stroke=\"#ffd93d\" stroke-width=\"2\"/>\n      <text x=\"50\" y=\"22\" font-family=\"Arial\" font-size=\"10\" fill=\"#ffd93d\" text-anchor=\"middle\" class=\"pulse-anim\">⚖️ 分数加权</text>\n    </g>\n    \n    <!-- MMR & Temporal -->\n    <g transform=\"translate(30, 200)\">\n      <rect x=\"0\" y=\"0\" width=\"90\" height=\"50\" rx=\"8\" fill=\"#1e272e\" stroke=\"#a55eea\" stroke-width=\"2\"/>\n      <text x=\"45\" y=\"18\" font-family=\"Arial\" font-size=\"9\" fill=\"#a55eea\" text-anchor=\"middle\" font-weight=\"bold\">MMR</text>\n      <text x=\"45\" y=\"35\" font-family=\"Arial\" font-size=\"8\" fill=\"#888\" text-anchor=\"middle\">多样性重排</text>\n    </g>\n    \n    <g transform=\"translate(140, 200)\">\n      <rect x=\"0\" y=\"0\" width=\"90\" height=\"50\" rx=\"8\" fill=\"#1e272e\" stroke=\"#00d9ff\" stroke-width=\"2\"/>\n      <text x=\"45\" y=\"18\" font-family=\"Arial\" font-size=\"9\" fill=\"#00d9ff\" text-anchor=\"middle\" font-weight=\"bold\">⏰ Temporal</text>\n      <text x=\"45\" y=\"35\" font-family=\"Arial\" font-size=\"8\" fill=\"#888\" text-anchor=\"middle\">时间衰减</text>\n    </g>\n  </g>\n\n  <!-- ==================== RIGHT: Output ==================== -->\n  \n  <!-- Memory Tools -->\n  <g transform=\"translate(650, 200)\">\n    <rect x=\"0\" y=\"0\" width=\"200\" height=\"200\" rx=\"15\" fill=\"#1e272e\" stroke=\"#00d9ff\" stroke-width=\"2\"/>\n    <text x=\"100\" y=\"30\" font-family=\"Arial\" font-size=\"16\" fill=\"#00d9ff\" text-anchor=\"middle\" font-weight=\"bold\">🔧 记忆工具</text>\n    \n    <!-- memory_search -->\n    <g transform=\"translate(20, 50)\">\n      <rect x=\"0\" y=\"0\" width=\"160\" height=\"50\" rx=\"10\" fill=\"#2d3436\" stroke=\"#ffd93d\" stroke-width=\"2\"/>\n      <text x=\"80\" y=\"20\" font-family=\"Arial\" font-size=\"11\" fill=\"#ffd93d\" text-anchor=\"middle\" font-weight=\"bold\">memory_search</text>\n      <text x=\"80\" y=\"38\" font-family=\"Arial\" font-size=\"9\" fill=\"#888\" text-anchor=\"middle\">语义搜索 → snippets</text>\n    </g>\n    \n    <!-- memory_get -->\n    <g transform=\"translate(20, 110)\">\n      <rect x=\"0\" y=\"0\" width=\"160\" height=\"50\" rx=\"10\" fill=\"#2d3436\" stroke=\"#00ff88\" stroke-width=\"2\"/>\n      <text x=\"80\" y=\"20\" font-family=\"Arial\" font-size=\"11\" fill=\"#00ff88\" text-anchor=\"middle\" font-weight=\"bold\">memory_get</text>\n      <text x=\"80\" y=\"38\" font-family=\"Arial\" font-size=\"9\" fill=\"#888\" text-anchor=\"middle\">精准读取 → 原文</text>\n    </g>\n  </g>\n\n  <!-- Data Flow Lines -->\n  \n  <!-- Memory files to search engine -->\n  <path d=\"M 250 170 Q 280 170 320 230\" stroke=\"#ffd93d\" stroke-width=\"2\" fill=\"none\" stroke-dasharray=\"5,5\" class=\"dash-anim\"/>\n  <path d=\"M 250 340 Q 280 340 320 280\" stroke=\"#00d9ff\" stroke-width=\"2\" fill=\"none\" stroke-dasharray=\"5,5\" class=\"dash-anim\"/>\n  <path d=\"M 250 520 Q 300 520 350 400\" stroke=\"#6c5ce7\" stroke-width=\"2\" fill=\"none\" stroke-dasharray=\"5,5\" class=\"dash-anim\"/>\n  \n  <!-- Search to tools -->\n  <path d=\"M 580 340 Q 620 340