=\"slide-in\">\n    <rect x=\"0\" y=\"0\" width=\"120\" height=\"150\" rx=\"15\" fill=\"#2d3436\" stroke=\"#00d9ff\" stroke-width=\"3\"/>\n    <text x=\"60\" y=\"30\" font-family=\"Arial\" font-size=\"16\" fill=\"#00d9ff\" text-anchor=\"middle\" font-weight=\"bold\">Client</text>\n    <text x=\"60\" y=\"50\" font-family=\"Arial\" font-size=\"10\" fill=\"#888\" text-anchor=\"middle\">CLI / Web UI</text>\n    <text x=\"60\" y=\"65\" font-family=\"Arial\" font-size=\"10\" fill=\"#888\" text-anchor=\"middle\">macOS App</text>\n    <text x=\"60\" y=\"80\" font-family=\"Arial\" font-size=\"10\" fill=\"#888\" text-anchor=\"middle\">Automation</text>\n    \n    <!-- Request/Response icons -->\n    <g transform=\"translate(30, 100)\" class=\"pulse-anim\">\n      <rect x=\"0\" y=\"0\" width=\"60\" height=\"35\" rx=\"8\" fill=\"#1e272e\" stroke=\"#00d9ff\"/>\n      <text x=\"30\" y=\"22\" font-family=\"Arial\" font-size=\"9\" fill=\"#00d9ff\" text-anchor=\"middle\">req:connect</text>\n    </g>\n  </g>\n\n  <!-- Gateway -->\n  <g transform=\"translate(400, 180)\" class=\"slide-in\" style=\"animation-delay: 0.2s\">\n    <rect x=\"0\" y=\"0\" width=\"150\" height=\"200\" rx=\"20\" fill=\"#0f3460\" stroke=\"#e94560\" stroke-width=\"3\"/>\n    <text x=\"75\" y=\"35\" font-family=\"Arial\" font-size=\"18\" fill=\"#fff\" text-anchor=\"middle\" font-weight=\"bold\">🦞 Gateway</text>\n    <text x=\"75\" y=\"55\" font-family=\"Arial\" font-size=\"10\" fill=\"#aaa\" text-anchor=\"middle\">WebSocket Server</text>\n    \n    <!-- Connection state -->\n    <g transform=\"translate(20, 75)\">\n      <rect x=\"0\" y=\"0\" width=\"110\" height=\"40\" rx=\"8\" fill=\"#1e272e\" stroke=\"#636e72\"/>\n      <text x=\"55\" y=\"18\" font-family=\"Arial\" font-size=\"10\" fill=\"#888\" text-anchor=\"middle\">State: Disconnected</text>\n      <text x=\"55\" y=\"32\" font-family=\"Arial\" font-size=\"8\" fill=\"#666\" text-anchor=\"middle\">→ Validating...</text>\n    </g>\n    \n    <!-- Validation -->\n    <g transform=\"translate(20, 125)\">\n      <rect x=\"0\" y=\"0\" width=\"110\" height=\"40\" rx=\"8\" fill=\"#1e272e\" stroke=\"#00ff88\"/>\n      <text x=\"55\" y=\"25\" font-family=\"Arial\" font-size=\"10\" fill=\"#00ff88\" text-anchor=\"middle\">✓ Auth OK</text>\n    </g>\n  </g>\n\n  <!-- Arrow 1: Connect Request -->\n  <g transform=\"translate(220, 260)\" class=\"fade-in\" style=\"animation-delay: 0.3s\">\n    <path d=\"M 0 10 L 100 10\" stroke=\"#00d9ff\" stroke-width=\"3\" fill=\"none\" marker-end=\"url(#arrow1)\"/>\n    <text x=\"50\" y=\"0\" font-family=\"Arial\" font-size=\"10\" fill=\"#00d9ff\" text-anchor=\"middle\">connect frame</text>\n    <text x=\"50\" y=\"-12\" font-family=\"Arial\" font-size=\"8\" fill=\"#888\" text-anchor=\"middle\">{type:\"req\", id, method}</text>\n  </g>\n  \n  <!-- Arrow marker -->\n  <defs>\n    <marker id=\"arrow1\" markerWidth=\"10\" markerHeight=\"10\" refX=\"9\" refY=\"3\" orient=\"auto\">\n      <path d=\"M0,0 L0,6 L9,3 z\" fill=\"#00d9ff\"/>\n    </marker>\n    <marker id=\"arrow2\" markerWidth=\"10\" markerHeight=\"10\" refX=\"9\" refY=\"3\" orient=\"auto\">\n      <path d=\"M0,0 L0,6 L9,3 z\" fill=\"#00ff88\"/>\n    </marker>\n  </defs>\n\n  <!-- Arrow 2: Response -->\n  <g transform=\"translate(220, 320)\" class=\"fade-in\" style=\"animation-delay: 0.5s\">\n    <path d=\"M 100 10 L 0 10\" stroke=\"#00ff88\" stroke-width=\"3\" fill=\"none\" marker-end=\"url(#arrow2)\"/>\n    <text x=\"50\" y=\"0\" font-family=\"Arial\" font-size=\"10\" fill=\"#00ff88\" text-anchor=\"middle\">res: hello-ok</text>\n    <text x=\"50\" y=\"-12\" font-family=\"Arial\" font-size=\"8\" fill=\"#888\" text-anchor=\"middle\">snapshot: presence, health</text>\n  </g>\n\n  <!-- Sequence Diagram Box -->\n  <g transform=\"translate(650, 150)\" class=\"fade-in\" style=\"animation-delay: 0.6s\">\n    <rect x=\"0\" y=\"0\" width=\"200\" height=\"250\" rx=\"10\" fill=\"#1e272e\" stroke=\"#636e72\" stroke-width=\"2\"/>\n    <text x=\"100\" y=\"25\" font-family=\"Arial\" font-size=\"12\" fill=\"#fff\" text-anchor=\"middle\" font-weight=\"bold\">序列流程</text>\n    \n    <!-- Step 1 -->\n    <g transform=\"translate(15, 40)\">\n      <circle cx=\"8\" cy=\"8\" r=\"8\" fill=\"#00d9ff\"/>\n      <text x=\"25\" y=\"12\" font-family=\"Arial\" font-size=\"9\" fill=\"#ccc\">Client → Gateway</text>\n      <text x=\"25\" y=\"24\" font-family=\"Arial\" font-size=\"8\" fill=\"#888\">req:connect</text>\n    </g>\n    \n    <!-- Step 2 -->\n    <g transform=\"translate(15, 70)\">\n      <circle cx=\"8\" cy=\"8\" r=\"8\" fill=\"#00ff88\"/>\n      <text x=\"25\" y=\"12\" font-family=\"Arial\" font-size=\"9\" fill=\"#ccc\">Gateway → Client</text>\n      <text x=\"25\" y=\"24\" font-family=\"Arial\" font-size=\"8\" fill=\"#888\">res (ok) + snapshot</text>\n    </g>\n    \n    <!-- Step 3 -->\n    <g transform=\"translate(15, 100)\">\n      <circle cx=\"8\" cy=\"8\" r=\"8\" fill=\"#ffd93d\"/>\n      <text x=\"25\" y=\"12\" font-family=\"Arial\" font-size=\"9\" fill=\"#ccc\">Gateway → Client</text>\n      <text x=\"25\" y=\"24\" font-family=\"Arial\" font-size=\"8\" fill=\"#888\">event:presence</text>\n    </g>\n    \n    <!-- Step 4 -->\n    <g transform=\"translate(15, 130)\">\n      <circle cx=\"8\" cy=\"8\" r=\"8\" fill=\"#ffd93d\"/>\n      <text x=\"25\" y=\"12\" font-family=\"Arial\" font-size=\"9\" fill=\"#ccc\">Gateway → Client</text>\n      <text x=\"25\" y=\"24\" font-family=\"Arial\" font-size=\"8\" fill=\"#888\">event:tick</text>\n    </g>\n    \n    <!-- Step 5 -->\n    <g transform=\"translate(15, 160)\">\n      <circle cx=\"8\" cy=\"8\" r=\"8\" fill=\"#e94560\"/>\n      <text x=\"25\" y=\"12\" font-family=\"Arial\" font-size=\"9\" fill=\"#ccc\">Client → Gateway</text>\n      <text x=\"25\" y=\"24\" font-family=\"Arial\" font-size=\"8\" fill=\"#888\">req:agent</text>\n    </g>\n    \n    <!-- Step 6 -->\n    <g transform=\"translate(15, 190)\">\n      <circle cx=\"8\" cy=\"8\" r=\"8\" fill=\"#a55eea\"/>\n      <text x=\"25\" y=\"12\" font-family=\"Arial\" font-size=\"9\" fill=\"#ccc\">Gateway → Client</text>\n      <text x=\"25\" y=\"24\" font-family=\"Arial\" font-size=\"8\" fill=\"#888\">event:agent (stream)</text>\n    </g>\n    \n    <!-- Step 7 -->\n    <g transform=\"translate(15, 220)\">\n      <circle cx=\"8\" cy=\"8\" r=\"8\" fill=\"#00ff88\"/>\n      <text x=\"25\" y=\"12\" font-family=\"Arial\" font-size=\"9\" fill=\"#ccc\">Gateway → Client</text>\n      <text x=\"25\" y=\"24\" font-family=\"Arial\" font-size=\"8\" fill=\"#888\">res:agent (final)</text>\n    </g>\n  </g>\n\n  <!-- Auth Details -->\n  <g transform=\"translate(100, 450)\" class=\"fade-in\" style=\"animation-delay: 0.7s\">\n    <rect x=\"0\" y=\"0\" width=\"300\" height=\"120\" rx=\"10\" fill=\"#1e272e\" stroke=\"#ff6b6b\" stroke-width=\"2\"/>\n    <text x=\"150\" y=\"25\" font-family=\"Arial\" font-size=\"12\" fill=\"#ff6b6b\" text-anchor=\"middle\" font-weight=\"bold\">🔐 认证流程</text>\n    \n    <g transform=\"translate(20, 45)\">\n      <text x=\"0\" y=\"0\" font-family=\"Arial\" font-size=\"10\" fill=\"#ccc\">1. 首帧必须是 connect</text>\n    </g>\n    <g transform=\"translate(20, 65)\">\n      <text x=\"0\" y=\"0\" font-family=\"Arial\" font-size=\"10\" fill=\"#ccc\">2. 设备身份 + 签名验证</text>\n    </g>\n    <g transform=\"translate(20, 85)\">\n      <text x=\"0\" y=\"0\" font-family=\"Arial\" font-size=\"10\" fill=\"#ccc\">3. 幂等键用于 send/agent</text>\n    </g>\n    <g transform=\"translate(20, 105)\">\n      <text x=\"0\" y=\"0\" font-family=\"Arial\" font-size=\"10\" fill=\"#ccc\">4. 本地自动批准，远程需确认</text>\n    </g>\n  </g>\n\n  <!-- Protocol Details -->\n  <g transform=\"translate(450, 450)\" class=\"fade-in\" style=\"animation-delay: 0.8s\">\n    <rect x=\"0\" y=\"0\" width=\"200\" height=\"120\" rx=\"10\" fill=\"#1e272e\" stroke=\"#00d9ff\" stroke-width=\"2\"/>\n    <text x=\"100\" y=\"25\" font-family=\"Arial\" font-size=\"12\" fill=\"#00d9ff\" text-anchor=\"middle\" font-weight=\"bold\">📡 协议格式</text>\n    \n    <g transform=\"translate(20, 45)\">\n      <text x=\"0\" y=\"0\" font-family=\"monospace\" font-size=\"9\" fill=\"#888\">{\"type\":\"req\",</text>\n    </g>\n    <g transform=\"translate(20, 60)\">\n      <text x=\"0\" y=\"0\" font-family=\"monospace\" font-size=\"9\" fill=\"#888\"> \"id\", \"method\",</text>\n    </g>\n    <g transform=\"translate(20, 75)\">\n      <text x=\"0\" y=\"0\" font-family=\"monospace\" font-size=\"9\" fill=\"#888\"> \"params\"}</text>\n    </g>\n    <g transform=\"translate(20, 95)\">\n      <text x=\"0\" y=\"0\" font-family=\"Arial\" font-size=\"9\" fill=\"#666\">→ JSON over WebSocket</text>\n    </g>\n  </g>\n\n  <!-- Node Flow -->\n  <g transform=\"translate(680, 450)\" class=\"fade-in\" style=\"animation-delay: 0.9s\">\n    <rect x=\"0\" y=\"0\" width=\"180\" height=\"120\" rx=\"10\" fill=\"#1e272e\" stroke=\"#a55eea\" stroke-width=\"2\"/>\n    <text x=\"90\" y=\"25\" font-family=\"Arial\" font-size=\"12\" fill=\"#a55eea\" text-anchor=\"middle\" font-weight=\"bold\">📱 Node 连接</text>\n    \n    <g transform=\"translate(15, 45)\">\n      <text x=\"0\" y=\"0\" font-family=\"Arial\" font-size=\"9\" fill=\"#ccc\">• role: \"node\"</text>\n    </g>\n    <g transform=\"translate(15, 60)\">\n      <text x=\"0\" y=\"0\" font-family=\"Arial\" font-size=\"9\" fill=\"#ccc\">• 设备身份</text>\n    </g>\n    <g transform=\"translate(15, 75)\">\n      <text x=\"0\" y=\"0\" font-family=\"Arial\" font-size=\"9\" fill=\"#ccc\">• caps/commands</text>\n    </g>\n    <g transform=\"translate(15, 90)\">\n      <text x=\"0\" y=\"0\" font-family=\"Arial\" font-size=\"9\" fill=\"#ccc\">• canvas/camera/screen</text>\n    </g>\n  </g>\n</svg>\n","file_path":"/home/admin/.openclaw/workspace/openclaw-connection-lifecycle.svg"}}],"api":"anthropic-messages","provider":"minimax-cn","model":"MiniMax-M2.5-highspeed","usage":{"input":26521,"output":3615,"cacheRead":12885,"cacheWrite":0,"totalTokens":43021,"cost":{"input":0.0159126,"output":0.008676,"cacheRead":0.00077